library(readr)
yard_trees_verified <- read_csv("~/Desktop/Jess_Honours/1 - Input/yard_trees_verified.csv")
View(yard_trees_verified)
library(readr)
ndg_cleaneddata_2025 <- read_csv("~/Desktop/Jess_Honours/1 - Input/ndg_cleaneddata_2025.csv")
View(ndg_cleaneddata_2025)
library(readr)
ndg_cleaneddata_2024 <- read_csv("~/Desktop/Jess_Honours/1 - Input/ndg_cleaneddata_2024.csv")
View(ndg_cleaneddata_2024)
View(ndg_cleaneddata_2024)
remove(ndg_cleaneddata_2024)
###################### EXTRACTING YARDS #################################
# 2024
data_2024 <-
read_csv("~/Desktop/Jess_Honours/1 - Input/ndg_cleaneddata_2024.csv")
View(data_2024)
View(ndg_cleaneddata_2025)
remove(ndg_cleaneddata_2025)
# 2025
data_2025 <-
read_csv("~/Desktop/Jess_Honours/1 - Input/ndg_cleaneddata_2025.csv")
yard_data_2024 <- data_2024[data_2024$Landtype=="yard", ]
View(yard_data_2024)
yard_data_2025 <- data_2025[data_2025$Landtype=="yard"]
yard_data_2025 <- data_2025[data_2025$Landtype=="yard",]
View(yard_data_2024)
class(yard_data_2024$Date)
############################### MIGRATORY PERIOD ###############################
# Defining the migratory period as start of surveys to June 1st
# 2024
migratory_data_2024 <- yard_data_2024[yard_data_2024$Date <= "2024-06-01",]
View(migratory_data_2024)
################################ BREEDING PERIOD ###############################
# Defining breeding period as June 2nd to end of surveys
# 2024
breeding_data_2024 <- yard_data_2024[yard_data_2024$Date > "2024-06-01",]
# 2025
migratory_data_2025 <- yard_data_2025[yard_data_2025$Date <= "2024-06-01",]
# 2025
breeding_data_2025 <- yard_data_2025[yard_data_2025$Date > "2024-06-01",]
################################# NEW DATASETS #################################
# Merge the datasets together
library(dplyr)
################################# NEW DATASETS #################################
# Stack the datasets together according to breeding vs migratory periods
# Migratory data
migratory_data <- rbind(migratory_data_2024, migratory_data_2025)
# Breeding data
breeding_data <- rbind(breeding_data_2024, breeding_data_2025)
View(breeding_data_2025)
View(breeding_data)
# Export a new dataset with just yard data from all years
yard_data <- rbind(yard_data_2024, yard_data_2025)
remove(yard_data)
# Export a new dataset with just yard data from all years
all_yard_data <- rbind(yard_data_2024, yard_data_2025)
write.csv(all_yard_data, file="cleaned_yard_data.csv", row.names=FALSE)
write.csv(migratory_data, file = "migratory_data.csv", row.names = FALSE)
write.csv(breeding_data, file = "breeding_data.csv", row.names = FALSE)
remove(yard_trees_verified)
yard_trees <- read_csv("~/Desktop/Jess_Honours/1 - Input/yard_trees_verified.csv")
write.csv(migratory_data, file = "cleaned_migratory_data.csv", row.names = FALSE)
write.csv(breeding_data, file = "cleaned_breeding_data.csv", row.names = FALSE)
View(yard_trees)
View(yard_trees)
library(dplyr)
library(readr)
cleaned_migratory_data <- read_csv("cleaned_migratory_data.csv")
