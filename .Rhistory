# Define buffer distances
buffers <- c(25, 50, 100, 200, 400)
class_props <- function(x, classes = 0:5) {
x <- x[!is.na(x)]
if (length(x) == 0) return(rep(NA, length(classes)))
tab <- table(factor(x, levels = classes))
prop <- as.numeric(tab) / sum(tab)
return(prop)
}
